# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfstate.backup
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
.terraform.lock.hcl

# Never commit real variable values or secrets.
terraform.tfvars
terraform.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# Local plan output
*.tfplan
tfplan.binary

# Secrets / credentials
*.pem
*.key
.env
.env.*
credentials
credentials.json

# Splunk — instance-specific overrides and downloaded add-ons never belong
# in version control (real email addresses, SMTP creds, IAM keys entered
# via Splunk Web all land under local/; the TA .tgz is a Splunkbase
# download, not something we redistribute).
splunk/apps/*/local/
splunk/splunk-ta-aws.tgz

# Editor / OS
.DS_Store
.idea/
.vscode/
